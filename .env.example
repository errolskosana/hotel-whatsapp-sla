# ---------- App ----------
APP_ENV=dev
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/hotel

# ---------- WhatsApp / Meta ----------
# Meta App Secret (for x-hub-signature-256 validation)
META_APP_SECRET=replace_me
# Webhook verification token (your chosen value, must match what you set in Meta dashboard)
WHATSAPP_VERIFY_TOKEN=replace_me

# ---------- Encryption ----------
# Fernet key for encrypting hotel WhatsApp access tokens at rest
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_MASTER_KEY=replace_me

# ---------- JWT Auth ----------
# Secret used to sign staff session tokens — use a long random string in production
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_me
# Hours until a session token expires (default: 8)
JWT_EXPIRY_HOURS=8

# ---------- Redis (Celery broker) ----------
# Default works with docker-compose.yml; change for remote Redis
REDIS_URL=redis://localhost:6379/0

# ---------- Web Push (VAPID) ----------
# Generate keys: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.public_key); print(v.private_key)"
VAPID_SUBJECT=mailto:it@yourhotel.com
VAPID_PUBLIC_KEY=replace_me
VAPID_PRIVATE_KEY=replace_me

# ---------- Seed demo hotel (optional) ----------
# If set, a demo hotel + rooms are created on first startup
SEED_HOTEL_NAME=Demo Hotel
SEED_HOTEL_PHONE_NUMBER_ID=replace_me
SEED_HOTEL_BUSINESS_E164=+27821234567
SEED_HOTEL_ACCESS_TOKEN=EAAG...replace_me
SEED_MANAGER_E164=+27829876543

# If set, a manager staff account is also created (used to log in at /login)
SEED_MANAGER_EMAIL=manager@demo.local
SEED_MANAGER_PASSWORD=replace_me
