# ---------- App ----------
APP_ENV=dev
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/hotel

# ---------- WhatsApp / Meta ----------
# Meta App Secret (for x-hub-signature-256 validation)
META_APP_SECRET=replace_me
# Webhook verification token (your chosen value, must match what you set in Meta dashboard)
WHATSAPP_VERIFY_TOKEN=replace_me

# ---------- Secrets ----------
# Fernet key for encrypting hotel access tokens at rest
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_MASTER_KEY=replace_me

# ---------- Web Push (VAPID) ----------
VAPID_SUBJECT=mailto:it@yourhotel.com
VAPID_PUBLIC_KEY=replace_me
VAPID_PRIVATE_KEY=replace_me

# ---------- Basic Auth (MVP) ----------
# Protects /dashboard/* and most /api/* routes
DASH_USER=admin
DASH_PASS=admin123

# ---------- Seed demo hotel (optional) ----------
SEED_HOTEL_NAME=Demo Hotel
SEED_HOTEL_PHONE_NUMBER_ID=1234567890
SEED_HOTEL_BUSINESS_E164=27821234567
SEED_HOTEL_ACCESS_TOKEN=EAAG...replace_me
SEED_MANAGER_E164=27829876543

# Optional: create a demo manager staff user in the DB
SEED_MANAGER_EMAIL=manager@demo.local
SEED_MANAGER_PASSWORD=manager123
